{
  "name": "br-operational-toolkit",
  "version": "0.1.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "watch": "tsc -w",
    "package": "npm run build && electron-builder"
  },
  "engines": {
    "node": "^20.18.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.6",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "BizRobo"
  ],
  "author": "JO",
  "license": "MIT",
  "description": "BizRobo! の運用を便利にするツールキットです。",
  "dependencies": {
    "electron-serve": "^1.3.0",
    "mysql2": "^3.14.2"
  },
  "build": {
    "appId": "com.bizrobo.opekai.br-operational-toolkit",
    "productName": "BR Operational Toolkit",
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "files": [
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../client/dist/br-operational-toolkit",
        "to": "app",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
